#include <iostream>
#include <unordered_map>

int main() {
    int N;
    std::cin >> N;

    std::unordered_map<int, int> freq;
    for (int i = 0; i < N; i++) {
        int x;
        std::cin >> x;
        freq[x]++;
    }

    for (const auto &i : freq) {
        if (i.second % 4 != 0) {
            std::cout << i.first << "\n";
            break;
        }
    }
}

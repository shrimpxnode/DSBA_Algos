def recurs(arr, n, i):
    maxx = i
    k = 2 * i + 1   
    r = 2 * i + 2   

    if k < n and arr[k] > arr[maxx]:
        maxx = k
    if r < n and arr[r] > arr[maxx]:
        maxx = r
    if maxx != i:
        arr[i], arr[maxx] = arr[maxx], arr[i]
        recurs(arr, n, maxx)

def heap_sort(arr):
    el = len(arr) // 2 - 1
    for i in range(el, -1, -1):
        recurs(arr, len(arr), i)

    for i in range(len(arr) - 1, 0, -1):
        arr[i], arr[0] = arr[0], arr[i]
        recurs(arr, i, 0)

    return arr

n = int(input())
print(*heap_sort(list(map(int, input().split()))))

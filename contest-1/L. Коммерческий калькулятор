#include <iostream>
#include <vector>
#include <queue>
#include <iomanip>


int main() {
    int n;
    std::cin >> n;

    std::priority_queue<long long, std::vector<long long>, std::greater<long long>> heap;
    for (int i = 0; i < n; ++i) {
        long long x;
        std::cin >> x;
        heap.push(x);
    }

    double total = 0.0;

    while (heap.size() > 1) {
        long long first = heap.top();
        heap.pop();
        long long second = heap.top();
        heap.pop();

        long long sum = first + second;
        heap.push(sum);
        total += sum * 0.05;  
    }

    std::cout << std::fixed << std::setprecision(2) << total << std::endl;

    return 0;
}
